{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build Project",
      "type": "shell",
      "command": "g++",
      "args": [
        "CODES/main.cpp",
        "CODES/ArrayFunctions.cpp",
        "-o",
        "CODES/main",
        "-std=c++17",
        "-Wall"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$gcc"],
      "detail": "Compiles main.cpp + ArrayFunctions.cpp together"
    },
    {
      "label": "Build & Run",
      "type": "shell",
      "command": "g++ CODES/main.cpp CODES/ArrayFunctions.cpp -o CODES/main -std=c++17 && ./CODES/main",
      "group": "build",
      "problemMatcher": ["$gcc"],
      "detail": "Compiles and runs the program"
    }
  ]
}
